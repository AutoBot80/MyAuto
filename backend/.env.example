# Copy to backend/.env and adjust. See app/config.py for full list.

DATABASE_URL=postgresql://user:pass@localhost:5432/auto_ai

# --- JWT auth ---
# When true, API accepts all requests as a dev user (DEALER_ID, admin). Do not use in production.
AUTH_DISABLED=false
# Required when AUTH_DISABLED=false — at least 32 random bytes (e.g. openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRE_MINUTES=480

# Optional: comma-separated browser origins (no spaces). When set, LAN regex CORS is disabled.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional body limits (bytes)
# MAX_JSON_BODY_BYTES=2097152
# Per uploaded file (default 512000 = 500 KB)
# UPLOAD_MAX_FILE_BYTES=512000
# Single-file POST routes: /qr-decode, /vision, /textract, /subdealer-challan/parse-scan (~1.2 × per-file cap)
# MAX_SINGLE_UPLOAD_BODY_BYTES=614400
# Whole POST /uploads multipart (several parts; default ~10 × 500 KB + overhead)
# MAX_UPLOAD_ROUTE_BODY_BYTES=5505024
# JSON string field length cap (default 300); portal URL keys (*_url) are exempt — see app/validation/text_limits.py
# MAX_TEXT_CHARS=300

# Bootstrap ``login_ref.pwd_hash`` (run from backend/ with venv active):
# python -c "from passlib.hash import bcrypt; print(bcrypt.hash('YourPassword'))"
# Then insert/update ``login_ref`` and ``login_roles_ref`` (role with admin_flag=Y for /admin/*).
