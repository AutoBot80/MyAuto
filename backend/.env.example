# Copy to .env and adjust. Required URLs are validated at app startup.

DATABASE_URL=

# Upload scans-v2: run AWS Textract calls in parallel (default true). Set false to force sequential calls.
# OCR_UPLOAD_PARALLEL_TEXTRACT=true
# OCR_UPLOAD_TEXTRACT_TIMEOUT_SEC=240

# DMS / Vahan / Insurance base URLs (required)
DMS_BASE_URL=https://example.com/dummy-dms
VAHAN_BASE_URL=https://example.com/dummy-vaahan
INSURANCE_BASE_URL=https://example.com/dummy-insurance

# --- DMS Playwright automation mode ---
# dummy = repo static HTML (enquiry.html, vehicles.html, …) under DMS_BASE_URL
# real  = Hero Connect / Siebel: navigate full absolute URLs (DMS_REAL_URL_*); no dummy #dms-* fills
DMS_MODE=dummy

# When DMS_MODE=real (or siebel, live, production, hero), set at least:
# DMS_REAL_URL_CONTACT=https://connect.heromotocorp.biz/siebel/app/edealerHMCL/enu/?SWECmd=GotoView&SWEView=...
# Optional further screens (same host, full query string as copied from browser):
# DMS_REAL_URL_VEHICLES=   # §6.1a In Transit branch: e.g. Vehicles Receipt → HMCL In Transit (Process Receipt)
# DMS_REAL_URL_PRECHECK=   # Optional separate Pre Check view; if unset, Pre Check is tried on DMS_REAL_URL_PDI first
# DMS_REAL_URL_PDI=
# DMS_REAL_URL_VEHICLE=
# DMS_REAL_URL_ENQUIRY=   # Recommended when customer_master.dms_contact_path=skip_find (My Enquiries / Buyer-CoBuyer before vehicles)
# DMS_REAL_URL_LINE_ITEMS=
# DMS_REAL_URL_REPORTS=

# Optional Siebel Open UI tuning (when DMS_MODE=real):
# DMS_SIEBEL_ACTION_TIMEOUT_MS=30000
# DMS_SIEBEL_NAV_TIMEOUT_MS=90000
# Siebel iframe scope: single selector or chain nested iframes (outer >> inner), e.g. iframe#shell >> iframe#s_0_26
# DMS_SIEBEL_CONTENT_FRAME_SELECTOR=iframe#s_0_26
# Extra iframe CSS roots to try before walking every frame (comma-separated):
# DMS_SIEBEL_AUTO_IFRAME_SELECTORS=iframe#_swecontent
# Longer wait after GotoView so Find/mobile applets render (ms):
# DMS_SIEBEL_POST_GOTO_WAIT_MS=8000
# Extra substrings matching the mobile field label (comma-separated):
# DMS_SIEBEL_MOBILE_ARIA_HINTS=Cellular,Main Phone

# Reuse an EXISTING Hero Connect / Siebel tab: a normal Edge window is invisible to Playwright.
# Start Edge with remote debugging, log in once, leave the tab open:
#   "C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe" --remote-debugging-port=9222
# Then set:
#   PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222
# Login URLs like .../enu/?SWECmd=Login&... match DMS_BASE_URL once CDP is connected.

# When the app launches Edge/Chrome itself, it uses --remote-debugging-port (default 9333) so you can
# attach DevTools or align PLAYWRIGHT_CDP_URL=http://127.0.0.1:9333. Set to 0 to disable.
# PLAYWRIGHT_MANAGED_REMOTE_DEBUG_PORT=9333

DMS_PLAYWRIGHT_HEADED=true
PLAYWRIGHT_KEEP_OPEN=false
