# Copy to .env and adjust. Required URLs are validated at app startup.

DATABASE_URL=

# Upload scans-v2: run AWS Textract calls in parallel (default true). Set false to force sequential calls.
# OCR_UPLOAD_PARALLEL_TEXTRACT=true
# OCR_UPLOAD_TEXTRACT_TIMEOUT_SEC=240

# --- Production portal base URLs (required, absolute https://...) ---
# DMS: Hero Connect / Siebel entry (same origin you log into in Edge). Not a path on this API server.
DMS_BASE_URL=https://connect.heromotocorp.biz/siebel/app/edealerHMCL/enu
# VAHAN: production RTO portal base (batch/cart Playwright is not implemented yet — set URL for future use / manual ops).
VAHAN_BASE_URL=https://vahan.parivahan.gov.in
# Insurance: Hero MISP partner login or your insurer portal root URL Playwright should open.
INSURANCE_BASE_URL=https://example-insurer-portal.example.com

# --- DMS Playwright (Siebel only; static training HTML was removed) ---
# Default is real Siebel. Optional aliases: siebel, live, production, hero. **dummy** is rejected at startup.
DMS_MODE=real

# Required for Fill DMS: full GotoView URL for Contact Find (Buyer/CoBuyer or equivalent).
# DMS_REAL_URL_CONTACT=https://connect.heromotocorp.biz/siebel/app/edealerHMCL/enu/?SWECmd=GotoView&SWEView=...
# Optional further screens (same host, full query string as copied from browser):
# DMS_REAL_URL_VEHICLES=   # In Transit branch (receipt / Process Receipt in prepare_vehicle)
# DMS_REAL_URL_PRECHECK=   # Not used by Playwright today (tab Pre-check/PDI on vehicle form / attach path)
# DMS_REAL_URL_PDI=       # Not used by Playwright today (same as PRECHECK)
# DMS_REAL_URL_VEHICLE=
# DMS_REAL_URL_ENQUIRY=
# DMS_REAL_URL_LINE_ITEMS=
# DMS_REAL_URL_REPORTS=

# Optional Siebel Open UI tuning:
# DMS_SIEBEL_ACTION_TIMEOUT_MS=30000
# DMS_SIEBEL_NAV_TIMEOUT_MS=90000
# DMS_SIEBEL_CONTENT_FRAME_SELECTOR=iframe#s_0_26
# DMS_SIEBEL_AUTO_IFRAME_SELECTORS=iframe#_swecontent
# DMS_SIEBEL_POST_GOTO_WAIT_MS=8000
# DMS_SIEBEL_INTER_ACTION_DELAY_MS=0
# DMS_SIEBEL_MOBILE_ARIA_HINTS=Cellular,Main Phone

# Reuse an EXISTING Hero Connect tab: start Edge with --remote-debugging-port=9222, then:
# PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222
# PLAYWRIGHT_MANAGED_REMOTE_DEBUG_PORT=9333

DMS_PLAYWRIGHT_HEADED=true
