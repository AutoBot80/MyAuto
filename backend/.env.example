# Copy to .env and adjust. Required URLs are validated at app startup.

DATABASE_URL=

# DMS / Vahan / Insurance base URLs (required)
DMS_BASE_URL=https://example.com/dummy-dms
VAHAN_BASE_URL=https://example.com/dummy-vaahan
INSURANCE_BASE_URL=https://example.com/dummy-insurance

# --- DMS Playwright automation mode ---
# dummy = repo static HTML (enquiry.html, vehicles.html, …) under DMS_BASE_URL
# real  = Hero Connect / Siebel: navigate full absolute URLs (DMS_REAL_URL_*); no dummy #dms-* fills
DMS_MODE=dummy

# When DMS_MODE=real (or siebel, live, production, hero), set at least:
# DMS_REAL_URL_CONTACT=https://connect.heromotocorp.biz/siebel/app/edealerHMCL/enu/?SWECmd=GotoView&SWEView=...
# Optional further screens (same host, full query string as copied from browser):
# DMS_REAL_URL_VEHICLES=
# DMS_REAL_URL_PDI=
# DMS_REAL_URL_VEHICLE=
# DMS_REAL_URL_ENQUIRY=
# DMS_REAL_URL_LINE_ITEMS=
# DMS_REAL_URL_REPORTS=

# Reuse an existing Edge/Chrome tab: start browser with --remote-debugging-port=9222
# PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222

DMS_PLAYWRIGHT_HEADED=true
PLAYWRIGHT_KEEP_OPEN=false
