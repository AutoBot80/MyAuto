[Unit]
Description=Run DATABASE_URL sync from RDS master secret periodically
Requires=saathi-rds-url-sync.service

[Timer]
# Tighten if RDS password can rotate: worst-case gap = ~this interval + restart (see DEPLOY.md).
OnBootSec=2m
OnUnitActiveSec=2m
AccuracySec=1m
Persistent=true

[Install]
WantedBy=timers.target
