# API base URL (optional; when unset, Vite dev proxy forwards to backend)
# VITE_API_URL=http://127.0.0.1:8000

# Dealer ID for this client instance; header shows this dealer's name from the API.
VITE_DEALER_ID=100001

# DMS / Vahan / Insurance navigation URLs are configured only in backend/.env
# (DMS_BASE_URL, VAHAN_BASE_URL, INSURANCE_BASE_URL). See backend/.env.example.
