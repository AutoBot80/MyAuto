# API base URL (optional; when unset, Vite dev proxy forwards to backend)
# VITE_API_URL=http://127.0.0.1:8000

# When true, skip the login screen (use only with backend AUTH_DISABLED=true for local dev).
# VITE_AUTH_DISABLED=true

# Default dealer ID before login; after sign-in, the token’s dealer is used.
VITE_DEALER_ID=100001

# Optional: shown in the header Welcome line until a Login screen sets the name in app state.
# VITE_LOGIN_NAME=Demo User

# DMS base URL defaults in backend app/hero_dms_defaults.py (optional DMS_BASE_URL override in backend/.env).
# VAHAN / Insurance: VAHAN_BASE_URL and INSURANCE_BASE_URL in backend/.env.

# Optional: local scanner root shown in Add Sales upload panel (parent of "landing" and "processed").
# The browser cannot open this path automatically; use "Set scanner folder…" once to grant access.
# VITE_SCANNER_ROOT=C:\Users\arya_\OneDrive\Desktop\Saathi Docs\scanner
