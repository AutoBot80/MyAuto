# API base URL (optional; when unset, Vite dev proxy forwards to backend)
# VITE_API_URL=http://127.0.0.1:8000

# When true, skip the login screen (use only with backend AUTH_DISABLED=true for local dev).
# VITE_AUTH_DISABLED=true

# Default dealer ID before login; after sign-in, the token’s dealer is used.
VITE_DEALER_ID=100001

# Optional: shown in the header Welcome line until a Login screen sets the name in app state.
# VITE_LOGIN_NAME=Demo User

# DMS / Vahan / Insurance navigation URLs are configured only in backend/.env
# (DMS_BASE_URL, VAHAN_BASE_URL, INSURANCE_BASE_URL). See backend/.env.example.
